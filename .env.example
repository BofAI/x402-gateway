# Gateway service
X402_GATEWAY_PORT=4020
X402_GATEWAY_PROVIDERS_DIR=/app/providers
X402_GATEWAY_LOG_LEVEL=info
X402_GATEWAY_PUBLIC_BASE_URL=http://host.docker.internal:4020
X402_FACILITATOR_URL=https://admin-facilitator.bankofai.io/
X402_PROVIDER_RECIPIENT_BSC_TESTNET=0x1234567890123456789012345678901234567890
X402_PROVIDER_RECIPIENT_TRON=TProviderWalletBase58
X402_PROVIDER_VENDOR_TRON=TVendorWalletBase58

# Local facilitator used by docker compose during gateway development.
MOCK_FACILITATOR_PORT=4021
MOCK_FACILITATOR_MODE=success

# Demo upstream used by docker compose during full gateway debugging.
DEMO_UPSTREAM_PORT=8080
DEMO_UPSTREAM_TOKEN=demo-upstream-token
ACME_API_TOKEN=demo-upstream-token
BANKOFAI_API_KEY=change-me

# Python SDK source used at image build time.
# Use the published package for normal builds.
X402_SDK_SPEC="bankofai-x402>=0.6.0"
# For branch-based integration builds, override with a git URL, for example:
# X402_SDK_SPEC=git+https://github.com/BofAI/x402.git@develop#subdirectory=python/x402

# Provider upstream secrets referenced by provider.yml auth blocks.
# Keep real values in .env or the production secret manager.
# ACME_WEATHER_API_KEY=
# BANKOFAI_API_KEY=
# TRON_GRID_API_KEY=

# Public URL used by external clients and catalog publishing.
# X402_GATEWAY_PUBLIC_BASE_URL=https://tm-x402-gateway.bankofai.io
